        tk.Label(sidebar, text="Drag: orbit camera\nWheel: zoom").pack(anchor="w")

        # Mouse bindings
        self.canvas.bind("<Button-1>", self.on_mouse_down)
        self.canvas.bind("<B1-Motion>", self.on_mouse_drag)
        self.canvas.bind("<MouseWheel>", self.on_wheel)       # Windows/macOS
        self.canvas.bind("<Button-4>", self.on_wheel_linux_up)   # Linux scroll up
        self.canvas.bind("<Button-5>", self.on_wheel_linux_down) # Linux scroll down

        # State
        self.running = False
        self.data_log = []
        self.trail3d = []
        self.ticks = 0

        self.a = None; self.e = None; self.i = None
        self.Omega = None; self.omega = None; self.M = None

        self.cx = self.canvas_w // 2
        self.cy = self.canvas_h // 2
        self.yaw = 0.8
        self.pitch = 0.4
        self.cam_dist = 1.0
        self.proj_f = min(self.canvas_w, self.canvas_h) * 0.9
        self.near_clip = 0.5
        self.drag_last = None

        self.current_epoch = None

    # ------------- UI Actions -------------
    def toggle_node_mode(self):
        global AVERAGE_LUNAR_NODE
        AVERAGE_LUNAR_NODE = (self.node_mode.get() == "Averaged Moon Node")

    def reset(self):
        self.stop()
        self.canvas.delete("all")
        self.data_log.clear()
        self.trail3d.clear()
        self.ticks = 0
        self.output.config(text="")

    def start(self):
        if self.running:
            return
        try:
            a_km = float(self.entries["Semi-Major Axis a (km)"].get())
            e    = float(self.entries["Eccentricity e"].get())
            i_deg= float(self.entries["Inclination i (deg)"].get())
            O0   = float(self.entries["Initial RAAN Ω0 (deg)"].get())
            w0   = float(self.entries["Initial ω0 (deg)"].get())
            M0   = float(self.entries["Initial M0 (deg)"].get())
        except Exception:
            self.output.config(text="Invalid input.")
            return

        a = a_km * 1000.0
        if a <= RE or e < 0.0 or e >= 0.999:
            self.output.config(text="Check a>RE and 0<=e<1.")
            return

        # initialize sim state (independent physics after this)
        self.a = a; self.e = e; self.i = math.radians(i_deg)
        self.Omega = math.radians(O0); self.omega = math.radians(w0); self.M = math.radians(M0)

        # camera range
        rmax = a * (1.0 + e)
        self.cam_dist = 3.5 * rmax

        self.trail3d.clear()
        self.data_log.clear()
        self.ticks = 0
        self.running = True
        self.step_loop()

    def stop(self):
        self.running = False

    # ------------- Camera / Mouse -------------
    def on_mouse_down(self, event):
        self.drag_last = (event.x, event.y)

    def on_mouse_drag(self, event):
        if self.drag_last is None:
            self.drag_last = (event.x, event.y); return
        dx = event.x - self.drag_last[0]
        dy = event.y - self.drag_last[1]
        self.drag_last = (event.x, event.y)
        self.yaw   += dx * 0.005
        self.pitch += dy * 0.005
        self.pitch = max(-math.pi/2+0.05, min(math.pi/2-0.05, self.pitch))
        if not self.running:
            self.redraw_last()

    def on_wheel(self, event):
        factor = 0.9 if event.delta > 0 else 1.1
        self.cam_dist = max(self.cam_dist * factor, 1.0)
        if not self.running:
            self.redraw_last()

    def on_wheel_linux_up(self, event):
        self.cam_dist = max(self.cam_dist * 0.9, 1.0)
        if not self.running:
            self.redraw_last()

    def on_wheel_linux_down(self, event):
        self.cam_dist = max(self.cam_dist * 1.1, 1.0)
        if not self.running:
            self.redraw_last()

    # ------------- Simulation Loop -------------
    def step_loop(self):
        if not self.running:
            return
        steps_chunk = 2000
        end_ticks = min(int(SIM_DAYS*86400.0/TIME_STEP), self.ticks + steps_chunk)
        while self.ticks < end_ticks and self.running:
            t_seconds = self.ticks * TIME_STEP

            # secular propagation (rad/s * dt)
            dO, dw, dM = secular_rates(self.a, self.e, self.i, self.Omega, t_seconds)
            self.Omega += dO * TIME_STEP
            self.omega += dw * TIME_STEP
            self.M     += dM * TIME_STEP

            # osculating pos from mean elements (Kepler)
            M_wrapped = self.M % (2.0*math.pi)
            E = solve_kepler(M_wrapped, self.e)
            f = 2.0 * math.atan2(math.sqrt(1.0 + self.e) * math.sin(E/2.0),
                                 math.sqrt(1.0 - self.e) * math.cos(E/2.0))
            r = self.a * (1.0 - self.e**2) / (1.0 + self.e * math.cos(f))
            x_p = r * math.cos(f); y_p = r * math.sin(f); z_p = 0.0

            # PQW->ECI: R = R3(Omega) * R1(i) * R3(omega)
            R_eci = matmul3(r3(self.Omega), matmul3(r1(self.i), r3(self.omega)))
            x_e, y_e, z_e = matvec3(R_eci, (x_p, y_p, z_p))

            self.trail3d.append((x_e, y_e, z_e))
            if len(self.trail3d) > TRAIL_MAX:
                self.trail3d.pop(0)

            if self.ticks % DRAW_EVERY == 0:
                self.redraw_last()

            if self.ticks % 300 == 0:
                self.data_log.append([
                    self.ticks * TIME_STEP,
                    (self.Omega % (2.0*math.pi))*180.0/math.pi,
                    (self.omega % (2.0*math.pi))*180.0/math.pi,
                    (self.M % (2.0*math.pi))*180.0/math.pi
                ])

            self.ticks += 1

        if self.running and self.ticks < int(SIM_DAYS*86400.0/TIME_STEP):
            self.root.after(1, self.step_loop)
        else:
            self.running = False
            self.output.config(text="Simulation finished. Use Save CSV to export.")

    # ------------- 3D View -------------
    def view_rotate(self, v):
        cy = math.cos(self.yaw); sy = math.sin(self.yaw)
        cx = math.cos(self.pitch); sx = math.sin(self.pitch)
        x, y, z = v
        xr =  cy*x + sy*z
        zr = -sy*x + cy*z
        yr =  cx*y - sx*zr
        zr2=  sx*y + cx*zr
        return xr, yr, zr2

    def project(self, v):
        xr, yr, zr = self.view_rotate(v)
        zc = zr + self.cam_dist
        if zc < self.near_clip:
            return None
        x2 = self.cx + self.proj_f * (xr / zc)
        y2 = self.cy - self.proj_f * (yr / zc)
        return (x2, y2)

    def redraw_last(self):
        self.canvas.delete("all")

        # equatorial grid circle (z=0)
        grid_r = RE * 4.0
        grid_pts = []
        for k in range(0, 361, 10):
            ang = math.radians(k)
            p = (grid_r*math.cos(ang), grid_r*math.sin(ang), 0.0)
            pr = self.project(p)
            if pr:
                grid_pts.append(pr)
        if len(grid_pts) > 1:
            flat = []
            for p in grid_pts:
                flat.extend(p)
            try:
                self.canvas.create_line(*flat, fill="gray", width=1)
            except Exception:
                self.canvas.create_line(grid_pts, fill="gray", width=1)

        # Earth point
        origin = self.project((0.0,0.0,0.0))
        if origin:
            x0, y0 = origin
            self.canvas.create_oval(x0-4, y0-4, x0+4, y0+4, fill="white", outline="white")

        # trail & satellite
        if len(self.trail3d) > 1:
            last = None
            for p3 in self.trail3d:
                pr = self.project(p3)
                if pr and last:
                    self.canvas.create_line(last[0], last[1], pr[0], pr[1], fill="cyan", width=1)
                last = pr
            last3 = self.trail3d[-1]
            pr = self.project(last3)
            if pr:
                x, y = pr
                self.canvas.create_oval(x-3, y-3, x+3, y+3, fill="red", outline="")

        years = (self.ticks * TIME_STEP) / (365.2422*86400.0)
        txt = "t={:.3f} yr  Ω={:.2f}°  ω={:.2f}°  M={:.2f}°".format(
            years,
            (self.Omega % (2.0*math.pi))*180.0/math.pi if self.Omega is not None else 0.0,
            (self.omega % (2.0*math.pi))*180.0/math.pi if self.omega is not None else 0.0,
            (self.M % (2.0*math.pi))*180.0/math.pi if self.M is not None else 0.0
        )
        if self.current_epoch:
            txt = f"{txt} | Epoch: {self.current_epoch.strftime('%Y-%m-%d %H:%M:%S')}"
        self.output.config(text=txt)

    # ------------- CSV I/O -------------
    def save_csv(self):
        if not self.data_log:
            self.output.config(text="No data to save yet.")
            return
        fn = filedialog.asksaveasfilename(defaultextension=".csv", filetypes=[("CSV Files","*.csv")])
        if not fn:
            return
        with open(fn, "w", newline="") as f:
            w = csv.writer(f)
            w.writerow(["Time (s)", "RAAN Ω (deg)", "Arg of Perigee ω (deg)", "Mean Anomaly M (deg)"])
            w.writerows(self.data_log)
        self.output.config(text=f"CSV saved: {fn}")

    # ------------- Loaders / Compare -------------
    def load_data(self):
        path = filedialog.askopenfilename(
            title="Load LAGEOS-1 data (CSV or TLE)",
            filetypes=[("CSV files","*.csv"),("TLE text","*.txt *.tle"),("All files","*.*")]
        )
        if not path:
            MB.showinfo("Load Data", "No file selected.")
            return
        ext = Path(path).suffix.lower()
        try:
            if ext == ".csv":
                recs = load_elements_from_csv(path)
                if not recs:
                    MB.showerror("Load Data", "CSV parsed, but no valid rows found.")
                    return
                ep, inc, raan, ecc, argp, M, a_m = recs[-1]["Epoch"], recs[-1]["i"], recs[-1]["RAAN"], recs[-1]["e"], recs[-1]["argp"], recs[-1]["M"], recs[-1]["a_m"]
            else:
                pairs = load_tle_pairs_from_text(path)
                parsed = []
                for l1, l2 in pairs:
                    try:
                        ep = parse_epoch_tle_line1(l1)
                        inc, raan, ecc, argp, M, n = parse_line2_elements(l2)
                        n_rad_s = n * 2.0 * math.pi / 86400.0
                        a_m = (MU_EARTH / (n_rad_s**2))**(1.0/3.0)
                        parsed.append((ep, inc, raan, ecc, argp, M, a_m))
                    except Exception:
                        continue
                if not parsed:
                    MB.showerror("Load Data", "Could not parse any TLE pairs in this file.")
                    return
                ep, inc, raan, ecc, argp, M, a_m = sorted(parsed, key=lambda x: x[0])[-1]

            # populate UI
            self.entries["Semi-Major Axis a (km)"].delete(0, tk.END); self.entries["Semi-Major Axis a (km)"].insert(0, f"{a_m/1000.0:.6f}")
            self.entries["Eccentricity e"].delete(0, tk.END);         self.entries["Eccentricity e"].insert(0, f"{ecc:.7f}")
            self.entries["Inclination i (deg)"].delete(0, tk.END);     self.entries["Inclination i (deg)"].insert(0, f"{inc:.6f}")
            self.entries["Initial RAAN Ω0 (deg)"].delete(0, tk.END);   self.entries["Initial RAAN Ω0 (deg)"].insert(0, f"{raan:.6f}")
            self.entries["Initial ω0 (deg)"].delete(0, tk.END);        self.entries["Initial ω0 (deg)"].insert(0, f"{argp:.6f}")
            self.entries["Initial M0 (deg)"].delete(0, tk.END);        self.entries["Initial M0 (deg)"].insert(0, f"{M:.6f}")
            self.current_epoch = ep
            self.epoch_label.config(text=f"Epoch: {ep.strftime('%Y-%m-%d %H:%M:%S')}")
            MB.showinfo("Load Data", "Loaded and populated fields from file.\n(Your simulation remains independent after Start.)")
        except Exception as e:
            MB.showerror("Load Data", f"Unexpected error:\n{e}")

    def compare_vs_data(self):
        path = filedialog.askopenfilename(
            title="Pick the same LAGEOS-1 data file (CSV or TLE)",
            filetypes=[("CSV files","*.csv"),("TLE text","*.txt *.tle"),("All files","*.*")]
        )
        if not path:
            return
        try:
            times, RAANs, ARGs, Ms = [], [], [], []
            ns_revday, a_kms = [], []
            ext = Path(path).suffix.lower()

            if ext == ".csv":
                recs = load_elements_from_csv(path)
                if len(recs) < 3:
                    MB.showerror("Compare", "Need at least 3 rows in CSV to estimate drifts.")
                    return
                for r in recs:
                    times.append(r["Epoch"])
                    RAANs.append(r["RAAN"])
                    ARGs.append(r["argp"])
                    Ms.append(r["M"])
                    if "a_m" in r and r["a_m"] is not None:
                        a_kms.append(r["a_m"]/1000.0)
            else:
                pairs = load_tle_pairs_from_text(path)
                parsed = []
                for l1, l2 in pairs:
                    try:
                        ep = parse_epoch_tle_line1(l1)
                        inc, raan, ecc, argp, M, n = parse_line2_elements(l2)
                        parsed.append((ep, raan, argp, M, n))
                    except Exception:
                        continue
                if len(parsed) < 3:
                    MB.showerror("Compare", "Need at least 3 TLE pairs to estimate drifts.")
                    return
                parsed.sort(key=lambda x: x[0])
                for ep, raan, argp, M, n in parsed:
                    times.append(ep); RAANs.append(raan); ARGs.append(argp); Ms.append(M)
                    ns_revday.append(n)

            # Build time base
            t0 = times[0]
            t_days = np.array([(t - t0).total_seconds()/86400.0 for t in times], dtype=float)

            # Unwrap for RAAN, ω
            RAAN_u = unwrap_deg(RAANs); ARG_u = unwrap_deg(ARGs)

            # OLS secular drifts for RAAN, ω
            r_RAAN = slope_deg_per_day(t_days, RAAN_u)
            r_ARG  = slope_deg_per_day(t_days, ARG_u)

            # Robust Ṁ observed:
            # 1) If we have n (rev/day) per record (TLE), compute time-weighted average of n.
            # 2) Else if we have a_km per record (CSV), compute n from each a and time-weight.
            # 3) Else, as a last resort, compute n from the CURRENT sim a_km in the UI.
            if len(ns_revday) >= 2:
                dt = np.diff(t_days)
                n_mid = (np.array(ns_revday[:-1]) + np.array(ns_revday[1:]))/2.0
                n_obs = weighted_avg(n_mid, dt)
                M_obs_degday = 360.0 * n_obs
            elif len(a_kms) >= 2:
                dt = np.diff(t_days)
                n_mid = (np.array([revday_from_a_km(x) for x in a_kms[:-1]]) +
                         np.array([revday_from_a_km(x) for x in a_kms[1:]])) / 2.0
                n_obs = weighted_avg(n_mid, dt)
                M_obs_degday = 360.0 * n_obs
            else:
                try:
                    a_km_ui = float(self.entries["Semi-Major Axis a (km)"].get())
                except Exception:
                    MB.showerror("Compare", "Cannot infer mean motion for Ṁ. Ensure the CSV has either n (rev/day) or a (km), or the UI 'a (km)' is filled.")
                    return
                M_obs_degday = 360.0 * revday_from_a_km(a_km_ui)

            # Model predicted drifts at start epoch (rad/s -> deg/day)
            try:
                a_km = float(self.entries["Semi-Major Axis a (km)"].get())
                e    = float(self.entries["Eccentricity e"].get())
                i_deg= float(self.entries["Inclination i (deg)"].get())
                O0   = float(self.entries["Initial RAAN Ω0 (deg)"].get())
            except Exception:
                MB.showerror("Compare", "Please ensure a,e,i,Ω0 are filled.")
                return

            a_m = a_km * 1000.0; i = math.radians(i_deg); O0r = math.radians(O0)
            dO, dw, dM = secular_rates(a_m, e, i, O0r, 0.0)
            todeg = 180.0/math.pi
            model_RAAN = dO * todeg * 86400.0
            model_ARG  = dw * todeg * 86400.0
            model_M    = dM * todeg * 86400.0

            # Show comparison
            win = tk.Toplevel(self.root); win.title("Comparison — Observed (from file) vs Model")
            txt = tk.Text(win, width=80, height=16); txt.pack(fill="both", expand=True)
            txt.insert("end", "Observed OLS drifts from file (deg/day)\n")
            txt.insert("end", f"  RAAN: {r_RAAN:.6f}\n")
            txt.insert("end", f"  ω:    {r_ARG:.6f}\n")
            txt.insert("end", f"  M:    {M_obs_degday:.6f}   (from mean motion)\n\n")
            txt.insert("end", "Model predicted drifts (deg/day)\n")
            txt.insert("end", f"  RAAN: {model_RAAN:.6f}\n")
            txt.insert("end", f"  ω:    {model_ARG:.6f}\n")
            txt.insert("end", f"  M:    {model_M:.6f}\n")
            txt.configure(state="disabled")
        except Exception as e:
            MB.showerror("Compare", f"Unexpected error:\n{e}")

