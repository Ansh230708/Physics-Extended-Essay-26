# ===================== CONSTANTS (SI)
MU_EARTH = 3.986004418e14       # m^3/s^2
MU_SUN   = 1.32712440018e20     # m^3/s^2
MU_MOON  = 4.9048695e12         # m^3/s^2
RE       = 6_378_137.0          # m
J2       = 1.08262668e-3

A_SUN  = 1.495978707e11         # m
E_SUN  = 0.0167
A_MOON = 384_400e3              # m
E_MOON = 0.0549

OBLIQUITY = math.radians(23.439281)  # Sun plane tilt vs equator
I_LUNAR   = math.radians(23.5)       # effective lunar tilt (averaged model)
LUNAR_NODE_RATE = -2.0 * math.pi / (18.6 * 365.2422 * 86400.0)  # rad/s

# ===================== SIM CONFIG
SIM_DAYS     = 730      # total sim time (2 years)
TIME_STEP    = 60.0     # seconds
DRAW_EVERY   = 800      # draw every N steps
TRAIL_MAX    = 1200     # trail cap
AVERAGE_LUNAR_NODE = True  # default: averaged lunar node

# ===================== MATH HELPERS
def solve_kepler(M, e):
    E = M
    for _ in range(12):
        f  = E - e * math.sin(E) - M
        fp = 1.0 - e * math.cos(E)
        E -= f / fp
    return E

def r3(theta):
    c = math.cos(theta); s = math.sin(theta)
    return ((c,-s,0.0),(s,c,0.0),(0.0,0.0,1.0))

def r1(theta):
    c = math.cos(theta); s = math.sin(theta)
    return ((1.0,0.0,0.0),(0.0,c,-s),(0.0,s,c))

def matmul3(A, B):
    return (
        (A[0][0]*B[0][0]+A[0][1]*B[1][0]+A[0][2]*B[2][0],
         A[0][0]*B[0][1]+A[0][1]*B[1][1]+A[0][2]*B[2][1],
         A[0][0]*B[0][2]+A[0][1]*B[1][2]+A[0][2]*B[2][2]),
        (A[1][0]*B[0][0]+A[1][1]*B[1][0]+A[1][2]*B[2][0],
         A[1][0]*B[0][1]+A[1][1]*B[1][1]+A[1][2]*B[2][1],
         A[1][0]*B[0][2]+A[1][1]*B[1][2]+A[1][2]*B[2][2]),
        (A[2][0]*B[0][0]+A[2][1]*B[1][0]+A[2][2]*B[2][0],
         A[2][0]*B[0][1]+A[2][1]*B[1][1]+A[2][2]*B[2][1],
         A[2][0]*B[0][2]+A[2][1]*B[1][2]+A[2][2]*B[2][2])
    )

def matvec3(A, v):
    return (
        A[0][0]*v[0]+A[0][1]*v[1]+A[0][2]*v[2],
        A[1][0]*v[0]+A[1][1]*v[1]+A[1][2]*v[2],
        A[2][0]*v[0]+A[2][1]*v[1]+A[2][2]*v[2]
    )

def mutual_inclination(i_sat, tilt_plane, Omega_sat, Omega_plane):
    c = (math.cos(i_sat)*math.cos(tilt_plane) +
         math.sin(i_sat)*math.sin(tilt_plane)*math.cos(Omega_sat - Omega_plane))
    return math.acos(max(-1.0, min(1.0, c)))

def third_body_factor(mu_body, a_sat, a_body, e_body):
    return (mu_body / MU_EARTH) * (a_sat / a_body)**3 / (1.0 - e_body**2)**1.5

def secular_rates(a, e, i, Omega, t_seconds):
    # mean motion
    n0 = math.sqrt(MU_EARTH / a**3)

    den12 = (1.0 - e**2)**2
    den32 = (1.0 - e**2)**1.5

    # J2 seculars
    dOmega_J2 = -1.5 * n0 * J2 * (RE / a)**2 * math.cos(i) / den12
    domega_J2 =  0.75 * n0 * J2 * (RE / a)**2 * (5.0*math.cos(i)**2 - 1.0) / den12
    dM_corr_J2 = 0.75 * n0 * J2 * (RE / a)**2 * (3.0*math.sin(i)**2 - 2.0) / den32

    # Sun (double-averaged)
    i_sun = mutual_inclination(i, OBLIQUITY, Omega, 0.0)
    A_sun = third_body_factor(MU_SUN, a, A_SUN, E_SUN)
    dOmega_sun = -1.5 * n0 * A_sun * math.cos(i_sun)
    domega_sun =  0.75 * n0 * A_sun * (5.0*math.cos(i_sun)**2 - 1.0)
    dM_corr_sun = - n0 * A_sun * (3.0*math.cos(i_sun)**2 - 1.0)

    # Moon (double-averaged; optional nodal regression)
    Omega_moon_plane = 0.0 if AVERAGE_LUNAR_NODE else (LUNAR_NODE_RATE * t_seconds)
    i_moon = mutual_inclination(i, I_LUNAR, Omega, Omega_moon_plane)
    A_moon = third_body_factor(MU_MOON, a, A_MOON, E_MOON)
    dOmega_moon = -1.5 * n0 * A_moon * math.cos(i_moon)
    domega_moon =  0.75 * n0 * A_moon * (5.0*math.cos(i_moon)**2 - 1.0)
    dM_corr_moon = - n0 * A_moon * (3.0*math.cos(i_moon)**2 - 1.0)

    # totals (rad/s)
    dOmega_total = dOmega_J2 + dOmega_sun + dOmega_moon
    domega_total = domega_J2 + domega_sun + domega_moon
    dM_total     = n0 + dM_corr_J2 + dM_corr_sun + dM_corr_moon
    return dOmega_total, domega_total, dM_total

# ===================== FILE PARSERS =====================
def parse_epoch_tle_line1(line1: str) -> datetime:
    # YYDDD.DDDDD in cols 19-32 (1-based). Using 0-based slices here.
    yy = int(line1[18:20])
    year = 2000 + yy if yy < 57 else 1900 + yy
    doy = float(line1[20:32])
    day_int = int(doy); frac = doy - day_int
    return datetime(year, 1, 1) + timedelta(days=day_int - 1) + timedelta(days=frac)

def parse_line2_elements(line2: str):
    # standard TLE slices (0-based)
    inc  = float(line2[8:16])           # deg
    raan = float(line2[17:25])          # deg
    ecc  = float(f"0.{line2[26:33].strip()}")  # implied decimal
    argp = float(line2[34:42])          # deg
    M    = float(line2[43:51])          # deg
    n    = float(line2[52:63])          # rev/day
    return inc, raan, ecc, argp, M, n

def load_tle_pairs_from_text(path: str):
    lines = [ln.strip() for ln in Path(path).read_text().splitlines() if ln.strip()]
    pairs = []
    i = 0
    while i < len(lines) - 1:
        if lines[i].startswith("1 ") and lines[i+1].startswith("2 "):
            pairs.append((lines[i], lines[i+1]))
            i += 2
        else:
            i += 1
    return pairs

def try_parse_epoch_str(s: str):
    s = str(s).strip()
    if not s:
        return None
    # ISO-8601
    try:
        return datetime.fromisoformat(s)
    except Exception:
        pass
    # Common patterns
    for fmt in ("%Y-%m-%d %H:%M:%S", "%Y/%m/%d %H:%M:%S",
                "%Y-%m-%d", "%d/%m/%Y %H:%M:%S", "%d/%m/%Y"):
        try:
            return datetime.strptime(s, fmt)
        except Exception:
            pass
    # Excel serial number?
    try:
        val = float(s)
        origin = datetime(1899, 12, 30)
        return origin + timedelta(days=val)
    except Exception:
        pass
    # YYDDD.DDDDD (TLE-like string)
    try:
        if len(s) >= 5 and all(ch.isdigit() or ch == '.' for ch in s):
            yy = int(s[:2]); year = 2000 + yy if yy < 57 else 1900 + yy
            doy = float(s[2:]); day_int = int(doy); frac = doy - day_int
            return datetime(year, 1, 1) + timedelta(days=day_int - 1) + timedelta(days=frac)
    except Exception:
        pass
    return None

def load_elements_from_csv(path: str):
    """
    Accepts a CSV containing (case-insensitive) columns:
      - Epoch (ISO or parseable)
      - Inclination (deg) / i_deg / Inclination
      - RAAN (deg) / RAAN
      - Eccentricity / e
      - Arg of Perigee (deg) / omega_deg / ArgPerigee
      - Mean Anomaly (deg) / M_deg
      - Mean Motion (rev/day) / n_rev_day   (optional if a_km is given)
      - Semi-Major Axis a (km) / a_km       (optional; if missing, computed from n)
    Returns list of rows dicts, sorted by epoch, latest last.
    """
    with open(path, newline="") as f:
        rdr = csv.reader(f)
        rows = list(rdr)
    if not rows:
        return []
    header = [h.strip() for h in rows[0]]

    def idx_of(*names):
        for name in names:
            for j, h in enumerate(header):
                if h.strip().lower() == name.strip().lower():
                    return j
        return None

    idx_epoch = idx_of("Epoch", "epoch", "Date", "datetime", "time", "Timestamp")
    idx_i     = idx_of("Inclination (deg)", "Inclination", "i_deg", "i (deg)", "i")
    idx_raan  = idx_of("RAAN (deg)", "RAAN", "Omega (deg)", "Ω (deg)")
    idx_e     = idx_of("Eccentricity", "e")
    idx_argp  = idx_of("Arg of Perigee (deg)", "ArgPerigee", "omega_deg", "omega (deg)", "ω (deg)")
    idx_M     = idx_of("Mean Anomaly (deg)", "M_deg", "M (deg)")
    idx_n     = idx_of("Mean Motion (rev/day)", "n_rev_day", "n (rev/day)", "mean_motion")
    idx_a_km  = idx_of("Semi-Major Axis a (km)", "a_km", "a (km)")

    if idx_epoch is None:
        raise ValueError("CSV must include an 'Epoch' (time) column.")
    if any(x is None for x in [idx_i, idx_raan, idx_e, idx_argp, idx_M]) or (idx_n is None and idx_a_km is None):
        raise ValueError("CSV is missing one or more required columns: i, RAAN, e, argp, M, and either n (rev/day) or a_km.")

    data = []
    for r in rows[1:]:
        if not any(r):
            continue
        try:
            ep = try_parse_epoch_str(r[idx_epoch])
            if ep is None:
                continue
            inc = float(str(r[idx_i]).strip())
            raan = float(str(r[idx_raan]).strip())
            ecc = float(str(r[idx_e]).strip())
            argp = float(str(r[idx_argp]).strip())
            M = float(str(r[idx_M]).strip())
            if idx_a_km is not None and r[idx_a_km].strip() != "":
                a_km = float(str(r[idx_a_km]).strip())
                a_m = a_km * 1000.0
            else:
                n_rev_day = float(str(r[idx_n]).strip())
                n_rad_s = n_rev_day * 2.0 * math.pi / 86400.0
                a_m = (MU_EARTH / (n_rad_s**2))**(1.0/3.0)
            data.append({"Epoch": ep, "i": inc, "RAAN": raan, "e": ecc, "argp": argp, "M": M, "a_m": a_m})
        except Exception:
            continue
    data.sort(key=lambda d: d["Epoch"])
    return data

# ===================== NUMPY HELPERS =====================
def unwrap_deg(arr_deg):
    r = np.deg2rad(np.asarray(arr_deg, dtype=float))
    return np.rad2deg(np.unwrap(r))

def slope_deg_per_day(t_days, y_deg):
    x = np.asarray(t_days, dtype=float)
    y = np.asarray(y_deg, dtype=float)
    A = np.vstack([x, np.ones_like(x)]).T
    m, _ = np.linalg.lstsq(A, y, rcond=None)[0]
    return float(m)

def weighted_avg(values, weights):
    v = np.asarray(values, dtype=float)
    w = np.asarray(weights, dtype=float)
    if np.allclose(w.sum(), 0.0):
        return float(np.nan)
    return float((v * w).sum() / w.sum())

def revday_from_a_km(a_km):
    MU_EARTH_km = 398600.4418  # km^3/s^2
    n_rad_s = math.sqrt(MU_EARTH_km / (a_km**3))
    return n_rad_s * 86400.0 / (2.0 * math.pi)  # rev/day

